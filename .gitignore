.DS_Store

application/cache/*
!application/cache/index.html

application/logs/*
!application/logs/index.html

!application/*/.htaccess

# composer.lock sengaja di-track agar GitHub Actions bisa install dependensi dengan benar
tests/mocks/database/ci_test.sqlite

user_guide_src/build/*
user_guide_src/cilexer/build/*
user_guide_src/cilexer/dist/*
user_guide_src/cilexer/pycilexer.egg-info/*
# vendor/ sengaja di-track agar bisa langsung di-deploy tanpa Composer di CI
# /vendor/

# IDE Files
#-------------------------
/nbproject/
.idea/*

## Sublime Text cache files
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project
/tests/tests/
/tests/results/

# InfinityFree - tidak perlu .htaccess khusus

# Local environment configuration
.env

# Lampiran & temp uploads
/assets/lampiran/*
!/assets/lampiran/.gitkeep
!/assets/lampiran/index.html

/assets/temp_excel/*
!/assets/temp_excel/.gitkeep
!/assets/temp_excel/index.html
